---
/**
 * The wro.cpp horseshoe-magnet "C++" mark as an inline, transparent SVG.
 * Vectorized from the 2021 brand-book raster (wro-cpp-mark@2x.png); fills are
 * the canonical brand colors (#414142 ink, #EA541E orange, #3EB5E9 blue) and
 * the background is transparent, so it sits cleanly on the cream header.
 * Sized by the `size` prop (square).
 */
interface Props {
  /** Visual size in pixels (square). Defaults to 40. */
  size?: number;
  class?: string;
}
const { size = 40, class: className = '' } = Astro.props;
