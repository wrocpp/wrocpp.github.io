---
interface Props {
  href: string;
  title: string;
  summary: string;
  kind: 'matrix' | 'curated' | 'recipe' | 'integration';
  lastReviewed: Date;
  tags?: string[];
  draft?: boolean;
}
const { href, title, summary, kind, lastReviewed, tags = [], draft } = Astro.props;
const date = lastReviewed.toISOString().slice(0, 10);
---
<a href={href} class={`toolset-card is-${kind}${draft ? ' is-draft' : ''}`}>
  <div class="toolset-card__meta">
    {draft && <span class="toolset-card__draft">draft</span>}
    <span class={`toolset-card__kind is-${kind}`}>{kind}</span>
    <span class="sep">/</span>
    <time datetime={date}>reviewed {date}</time>
  </div>
  <h3 class="toolset-card__title">{title}</h3>
  <p class="toolset-card__summary">{summary}</p>
  {tags.length > 0 && (
    <ul class="toolset-card__tags" role="list">
      {tags.slice(0, 4).map((t) => (<li>#{t}</li>))}
    </ul>
  )}
</a>

<style>
  .toolset-card {
    display: block;
    padding: 1.4rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--ink-muted);
    text-decoration: none;
    color: var(--ink);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }
  .toolset-card:hover {
    transform: translateY(-2px);
    background: var(--paper);
  }
  .toolset-card.is-matrix      { border-left-color: var(--blue); }
  .toolset-card.is-curated     { border-left-color: var(--orange); }
  .toolset-card.is-recipe      { border-left-color: var(--ink); }
  .toolset-card.is-integration { border-left-color: var(--orange-hot); }
  .toolset-card.is-matrix:hover      { border-color: var(--blue); }
  .toolset-card.is-curated:hover     { border-color: var(--orange); }
  .toolset-card.is-integration:hover { border-color: var(--orange-hot); }

  .toolset-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  .toolset-card__meta .sep { color: var(--rule); }
  .toolset-card__kind.is-matrix      { color: var(--blue-deep); }
  .toolset-card__kind.is-curated     { color: var(--orange); }
  .toolset-card__kind.is-integration { color: var(--orange-hot); }

  .toolset-card__title {
    font-family: "Quicksand", system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .toolset-card__summary {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 0.98rem;
    line-height: 1.5;
    color: var(--ink-muted);
    margin-top: 0.5rem;
  }
  .toolset-card__tags {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    list-style: none;
    padding: 0;
  }
  .toolset-card__tags li {
    padding: 0.15rem 0.45rem;
    color: var(--ink-muted);
    background: var(--paper);
    border: 1px solid var(--rule);
  }
  .toolset-card__draft {
    background: var(--orange);
    color: var(--paper);
    padding: 0.05rem 0.4rem;
    font-weight: 700;
  }
</style>
