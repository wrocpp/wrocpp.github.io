---
import type { CollectionEntry } from 'astro:content';

interface Props {
  event: CollectionEntry<'events'>;
  compact?: boolean;
}
const { event, compact = false } = Astro.props;
const { title, episode, date, kind, location, venue, attendees, meetupUrl, recordingUrl, summary, talks } = event.data;
const dateStr = date.toISOString().slice(0, 10);
const isOnline = kind === 'meetup-online' || location?.toLowerCase() === 'online';
const kindClass = isOnline ? 'is-online' : 'is-inperson';
---
<article class={`event-card ${kindClass}${compact ? ' is-compact' : ''}`}>
  <header class="event-card__head">
    <div class="event-card__meta">
      <time datetime={dateStr}>{dateStr}</time>
      <span class="sep">/</span>
      <span>{isOnline ? 'online' : 'in-person'}</span>
      {episode && (<><span class="sep">/</span><span>#{episode}</span></>)}
      {attendees && (<><span class="sep">/</span><span>{attendees} attendees</span></>)}
    </div>
    <h3 class="event-card__title">{title}</h3>
    {venue && <div class="event-card__venue">{venue}</div>}
  </header>

  {!compact && summary && <p class="event-card__summary">{summary}</p>}

  {!compact && talks && talks.length > 0 && (
    <ul class="event-card__talks" role="list">
      {talks.map((t) => (
        <li>
          <div class="event-card__talk-title">{t.title}</div>
          <div class="event-card__talk-speaker">— {t.speaker}</div>
          {(t.recordingUrl || t.slidesUrl) && (
            <div class="event-card__talk-links">
              {t.recordingUrl && <a href={t.recordingUrl} target="_blank" rel="noopener">recording ↗</a>}
              {t.slidesUrl && <a href={t.slidesUrl} target="_blank" rel="noopener">slides ↗</a>}
            </div>
          )}
        </li>
      ))}
    </ul>
  )}

  {(meetupUrl || recordingUrl) && (
    <div class="event-card__actions">
      {recordingUrl && <a href={recordingUrl} target="_blank" rel="noopener" class="event-card__action is-primary">Watch recording ↗</a>}
      {meetupUrl && <a href={meetupUrl} target="_blank" rel="noopener" class="event-card__action">meetup.com ↗</a>}
    </div>
  )}
</article>
