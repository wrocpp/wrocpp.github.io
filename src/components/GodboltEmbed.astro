---
/**
 * "Run on Compiler Explorer" call-to-action.
 *
 * Renders a compact, on-brand card that opens the referenced short-link
 * on godbolt.org in a new tab. No iframe (CE's full UI embedded in a page
 * is cluttered and ships privacy dialogs). The actual code lives in the
 * adjacent code block in the post; this card is the "try it yourself"
 * handoff.
 *
 * Usage:
 *   <GodboltEmbed id="n4eK93vfv" title="40-line JSON serializer" />
 */
interface Props {
  /** clang-p2996 short-link ID (godbolt.org/z/<ID>). Prefix `TODO` -> placeholder. */
  id: string;
  /**
   * Optional GCC 16.1 short-link ID. When set, a second "Run on GCC 16.1"
   * button appears below the clang one (blue accent rule instead of orange).
   * Set when GCC produces equivalent output for the example -- not all
   * P2996 corners agree across the two implementations as of 2026-05-01.
   */
  gcc_id?: string;
  /** Headline for the card. */
  title?: string;
  /** Override the playground repo link shown in placeholder mode. */
  fallbackHref?: string;
  /** Subtitle for the clang button. Defaults to pinned compiler + flags. */
  subtitle?: string;
  /** Subtitle for the GCC button. */
  gcc_subtitle?: string;
  /**
   * GCC-16-only example: the primary button points at the `id` link but is
   * labelled GCC 16.1, and the badge reads "Tested: GCC 16.1 only". Use for
   * features clang-p2996 does not implement yet (e.g. `std::meta::current_function`).
   */
  gccOnly?: boolean;
}
const {
  id,
  gcc_id,
  title = 'Run this example',
  subtitle = 'clang_bb_p2996 · -std=c++26 -freflection-latest -stdlib=libc++',
  gcc_subtitle = 'g161 (GCC 16.1) · -std=c++26 -freflection',
  fallbackHref = 'https://github.com/wrocpp/cpp26-reflection-examples',
  gccOnly = false,
} = Astro.props;

const isPlaceholder = id.startsWith('TODO') || id === 'placeholder';
const href = `https://godbolt.org/z/${id}`;
const gccHref = gcc_id ? `https://godbolt.org/z/${gcc_id}` : null;
// Primary-button labelling: GCC-only examples flip the compiler name + subtitle.
const primaryCompiler = gccOnly ? 'GCC 16.1' : 'clang-p2996';
const primarySubtitle = gccOnly ? gcc_subtitle : subtitle;
// Compiler-support badge: only meaningful for real (non-placeholder) ids.
// "+ GCC 16.1" when a gcc_id was wired; otherwise the example is currently
// known to run on clang-p2996 only (per docs/gcc-16-1-compatibility.md).
const badgeLabel = isPlaceholder
  ? null
  : gccOnly
    ? 'Tested: GCC 16.1 only'
    : gcc_id
      ? 'Tested: clang-p2996 + GCC 16.1'
      : 'Tested: clang-p2996 only';
---
{isPlaceholder ? (
  <div class="ce-cta ce-cta--placeholder">
    <div class="ce-cta__main">
      <div class="ce-cta__eyebrow">// permalink pending</div>
      <div class="ce-cta__title">Click-to-run coming soon</div>
      <div class="ce-cta__sub">
        A Compiler Explorer permalink will live here once pinned. Until then, run it locally from the <a href={fallbackHref}>playground repo</a>.
      </div>
    </div>
  </div>
) : (
  <div class="ce-cta-group">
    {badgeLabel && (
      <div class="ce-compiler-badge" aria-label={badgeLabel}>
        <span aria-hidden="true">&#9642;</span> {badgeLabel}
      </div>
    )}
    <a class="ce-cta" href={href} target="_blank" rel="noopener" aria-label={`Run on Compiler Explorer (${primaryCompiler}): ${title}`}>
      <span class="ce-cta__play" aria-hidden="true">▸</span>
      <span class="ce-cta__main">
        <span class="ce-cta__eyebrow">Run on Compiler Explorer</span>
        <span class="ce-cta__title">{title}</span>
        <span class="ce-cta__sub">{primarySubtitle}</span>
      </span>
      <span class="ce-cta__arrow" aria-hidden="true">↗</span>
    </a>
    {gccHref && (
      <a class="ce-cta ce-cta--secondary" href={gccHref} target="_blank" rel="noopener" aria-label={`Also run on GCC 16.1: ${title}`}>
        <span class="ce-cta__play" aria-hidden="true">▸</span>
        <span class="ce-cta__main">
          <span class="ce-cta__eyebrow">Also on GCC 16.1</span>
          <span class="ce-cta__title">{title}</span>
          <span class="ce-cta__sub">{gcc_subtitle}</span>
        </span>
        <span class="ce-cta__arrow" aria-hidden="true">↗</span>
      </a>
    )}
  </div>
)}

<style>
  .ce-cta-group { display: flex; flex-direction: column; gap: 0.5rem; margin: 1.5rem 0; }
  .ce-cta-group .ce-cta { margin: 0; }
  .ce-cta--secondary { border-left-color: var(--blue-deep) !important; }
  .ce-cta--secondary:hover { border-color: var(--blue-deep) !important; }
  .ce-cta--secondary .ce-cta__play { background: var(--blue-deep); }
  .ce-cta--secondary:hover .ce-cta__play { background: var(--blue); }
  .ce-cta--secondary .ce-cta__eyebrow { color: var(--blue-deep); }
  .ce-cta--secondary:hover .ce-cta__arrow { color: var(--blue-deep); }
  .ce-compiler-badge {
    font-size: 0.7rem;
    font-style: italic;
    color: var(--ink-faint);
    line-height: 1;
    margin: 0 0 0.1rem 0.1rem;
    letter-spacing: 0.01em;
  }
</style>
